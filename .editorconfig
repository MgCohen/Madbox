root = true

[*.cs]
# Scaffold Analyzer Severity Configuration
# Values: error | warning | suggestion | none
# Set to "none" to disable a rule entirely.
# Set to "error" to make a rule block compilation.

dotnet_diagnostic.SCA0001.severity = warning   # No comments on methods
dotnet_diagnostic.SCA0002.severity = warning   # Methods in order of usage
dotnet_diagnostic.SCA0003.severity = warning   # No nested function calls
dotnet_diagnostic.SCA0004.severity = warning   # Use curly brackets for methods
dotnet_diagnostic.SCA0005.severity = warning   # Avoid line breaks in signatures
dotnet_diagnostic.SCA0006.severity = warning   # Methods should be small
scaffold.SCA0006.max_lines = 8                 # Max lines per method body (default: 8)
dotnet_diagnostic.SCA0007.severity = warning   # Namespace matches folder structure
scaffold.SCA0007.root_namespace = Madbox       # Optional explicit root namespace (otherwise RootNamespace/MSBuildProjectName)
dotnet_diagnostic.SCA0008.severity = warning   # No _ or m_ prefixes on private fields
dotnet_diagnostic.SCA0009.severity = warning   # Private fields must be camelCase
dotnet_diagnostic.SCA0010.severity = warning   # Public members must be PascalCase
dotnet_diagnostic.SCA0011.severity = none      # Prefer Unity's Awaitable over Task/ValueTask
dotnet_diagnostic.SCA0012.severity = warning   # Public methods should start with invariant checks
dotnet_diagnostic.SCA0013.severity = warning   # Serializable Unity models should use [SerializeField] backing fields
dotnet_diagnostic.SCA0014.severity = warning   # Restrict static methods in non-static classes
dotnet_diagnostic.SCA0015.severity = warning   # Extra types: own file if shared/public, else place after primary type
dotnet_diagnostic.SCA0016.severity = warning   # Use TextMeshProUGUI instead of UnityEngine.UI.Text
dotnet_diagnostic.SCA0017.severity = warning   # Public constructors should start with invariant checks
dotnet_diagnostic.SCA0018.severity = warning   # MVVM classes should use module base types
dotnet_diagnostic.SCA0019.severity = warning   # MVVM generator attributes require references
dotnet_diagnostic.SCA0020.severity = warning   # Class member order
dotnet_diagnostic.SCA0021.severity = warning   # MVVM descendants must use bind APIs
dotnet_diagnostic.SCA0022.severity = warning   # Restrict cross-module runtime references
dotnet_diagnostic.SCA0023.severity = warning   # Required module folders exist
scaffold.SCA0023.required_folders = Runtime,Tests
# Optional module folders (not enforced): Container, Editor, Samples
scaffold.SCA0023.exempt_module_roots = Scaffold.Maps|Scaffold.Records|Scaffold.Types
scaffold.SCA0023.exempt_requirements = Scaffold.Records=Tests
dotnet_diagnostic.SCA0024.severity = warning   # Module asmdef placement/name convention
scaffold.SCA0024.suffix_folder_map = .Runtime=Runtime,.Tests=Tests,.PlayModeTests=Tests/PlayMode,.Samples=Samples,.Container=Container,.Editor=Editor,.Authoring=Authoring
scaffold.SCA0024.disallow_module_root_asmdef = true
scaffold.SCA0024.allow_unknown_suffix_in_any_subfolder = false
dotnet_diagnostic.SCA0026.severity = warning   # Restrict same-layer dependency usage during initialization call chains
dotnet_diagnostic.SCA0028.severity = warning   # Loop bodies require braces and next-line formatting
dotnet_diagnostic.SCA0029.severity = warning   # Conditionals require braces except inline single-statement if
dotnet_diagnostic.SCA0030.severity = warning   # Runtime dead code detection for non-public members

[Assets/Scripts/Infra/Model/**/*.cs]
# MVVM split modules keep legacy public namespaces under Scaffold.MVVM.
dotnet_diagnostic.SCA0007.severity = none

[Assets/Scripts/Infra/BaseMVVM/**/*.cs]
# MVVM split modules keep legacy public namespaces under Scaffold.MVVM.
dotnet_diagnostic.SCA0007.severity = none

[Assets/Scripts/Core/ViewModel/**/*.cs]
# MVVM split modules keep legacy public namespaces under Scaffold.MVVM.
dotnet_diagnostic.SCA0007.severity = none

[Assets/Scripts/App/View/**/*.cs]
# MVVM split modules keep legacy public namespaces under Scaffold.MVVM.
dotnet_diagnostic.SCA0007.severity = none

[Assets/Scripts/App/Bootstrap/Tests/LayerInitializationOrchestratorTests.cs]
dotnet_diagnostic.SCA0003.severity = none
dotnet_diagnostic.SCA0005.severity = none
dotnet_diagnostic.SCA0006.severity = none
dotnet_diagnostic.SCA0020.severity = none

